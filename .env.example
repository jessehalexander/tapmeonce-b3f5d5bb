# ─────────────────────────────────────────────
# TapMeOnce — Environment Variables
# Copy this to .env and fill in your values
# In Lovable: Project Settings → Environment Variables
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Razorpay ──────────────────────────────────
# Get from: Razorpay Dashboard → Settings → API Keys
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx

# ── Admin ─────────────────────────────────────
# The email that gets admin access to /admin panel
VITE_ADMIN_EMAIL=jesseh.alexander@gmail.com

# ── n8n Webhooks (already configured) ─────────
# AI Bio: https://airtribe.app.n8n.cloud/webhook/tapmeonce-profile
# Team Invite: https://airtribe.app.n8n.cloud/webhook/tapmeonce-team-invite
# (These are hardcoded — change in src/pages/Setup.tsx and src/pages/Dashboard.tsx)

# ── Optional: WhatsApp (for order tracking) ───
# See n8n workflows checklist in docs/N8N_WORKFLOWS.md
VITE_WHATSAPP_NOTIFY_WEBHOOK=https://airtribe.app.n8n.cloud/webhook/tapmeonce-order-notify
